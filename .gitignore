# ============================================================
# C++ Game Engine / Tooling Repository
# cross-platform friendly
# Covers: CMake, Ninja/Make, common IDEs, OS junk, docs artifacts,
# profiling output, local env files, and common package managers.
# ============================================================

# ------------------------------------------------------------
# Operating system files
# ------------------------------------------------------------
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes
.fseventsd
Icon?
Thumbs.db
Desktop.ini
$RECYCLE.BIN/

# ------------------------------------------------------------
# Version control / patch leftovers
# ------------------------------------------------------------
*.orig
*.rej
*.bak
*.tmp
*.temp
*.swp
*.swo
*~

# ------------------------------------------------------------
# Local environment / secrets / machine-specific config
# Do not store machine-local overrides or credentials.
# ------------------------------------------------------------
.env
.env.*
*.local
*.secret
*.secrets

# ------------------------------------------------------------
# Build outputs (generic)
# Keep source-controlled build scripts, ignore generated outputs.
# ------------------------------------------------------------
/build/
/build-*/
/bin/
/lib/
/out/
/dist/
/generated/
/artifacts/
/tmp/
/temp/

# Common generated binary/object files
*.o
*.obj
*.lo
*.la
*.a
*.lib
*.so
*.so.*
*.dylib
*.dll
*.exe
*.out
*.app
*.i*86
*.x86_64
*.hex
*.elf
*.pdb
*.idb
*.ilk
*.exp
*.manifest
*.minidump
*.dSYM/

# Coverage / profiling / debug artifacts
*.gcda
*.gcno
*.gcov
*.profraw
*.profdata
*.prof
*.dmp
*.stackdump
*.trace
*.tracy
*.qdrep
*.nsys-rep
*.nsys-rep.*
*.nsight-gfx
*.nv-gpudmp

# ------------------------------------------------------------
# CMake
# ------------------------------------------------------------
CMakeCache.txt
CMakeFiles/
cmake-build-*/
compile_commands.json
CTestTestfile.cmake
Testing/
DartConfiguration.tcl
cmake_install.cmake
install_manifest.txt
CMakeScripts/
CMakeUserPresets.json

# Generated package/config files
*.cmake.user

# ------------------------------------------------------------
# Ninja / Make / other generators
# ------------------------------------------------------------
.ninja_deps
.ninja_log
build.ninja
Makefile
makefile
GNUmakefile
*.make

# ------------------------------------------------------------
# Compiler dependency outputs
# ------------------------------------------------------------
*.d
*.dwo
*.dwp

# ------------------------------------------------------------
# ccache / sccache / compiler caches
# ------------------------------------------------------------
.ccache/
.sccache/

# ------------------------------------------------------------
# Testing
# Keep test code, ignore generated test output.
# ------------------------------------------------------------
/test-results/
/tests/output/
/tests/tmp/
/tests/.cache/

# ------------------------------------------------------------
# Documentation / site generators / exported docs artifacts
# Keep markdown/docs sources, ignore generated sites and exports.
# ------------------------------------------------------------
/site/
/public/
/docs/_site/
/docs/site/
/.jekyll-cache/
/.sass-cache/

# Exported document artifacts
*.pdf
*.docx
*.pptx

# If you plan to intentionally version exported docs, remove the lines above.

# ------------------------------------------------------------
# Asset pipeline scratch output
# Keep authored assets if you want them versioned, ignore intermediates.
# ------------------------------------------------------------
/assets/cache/
/assets/tmp/
/assets/intermediate/
/assets/derived/
/import-cache/
/shader-cache/

# Shader compiler outputs (project-local caches)
*.spv
*.air
*.metallib
*.dxil
*.cso

# ------------------------------------------------------------
# Logs / runtime output
# ------------------------------------------------------------
*.log
/logs/
/runtime-logs/

# ------------------------------------------------------------
# SDL / windowing / runtime local data
# ------------------------------------------------------------
*.sav
*.save
*.userprefs

# ------------------------------------------------------------
# Package managers / dependencies
# ------------------------------------------------------------
# vcpkg
/vcpkg_installed/
/vcpkg/buildtrees/
/vcpkg/downloads/
/vcpkg/packages/
/vcpkg/.vs/

# Conan
conan.lock
conanbuildinfo.*
conaninfo.txt

# ------------------------------------------------------------
# Python helpers (common for tools/scripts in engine repos)
# ------------------------------------------------------------
__pycache__/
*.py[cod]
.python-version
.venv/
venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ------------------------------------------------------------
# Node.js helpers (common for docs/editor tooling/scripts)
# ------------------------------------------------------------
node_modules/
.npm/
.pnpm-store/
.yarn/
.yarn-cache/
.parcel-cache/
coverage/

# ------------------------------------------------------------
# Rust helpers (only if you add rust-based tools later)
# ------------------------------------------------------------
/target/

# ------------------------------------------------------------
# Java / Kotlin helpers (only if tools are added later)
# ------------------------------------------------------------
.gradle/

# ------------------------------------------------------------
# Editor / IDE files
# ------------------------------------------------------------
# VS Code
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json.example
!.vscode/launch.json.example
!.vscode/tasks.json.example

# JetBrains / CLion
.idea/
*.iml

# Visual Studio
.vs/
*.VC.db
*.VC.opendb
*.sln.docstates
*.vcxproj.user
*.vcxproj.filters
*.opensdf
*.sdf
*.ipch/

# Xcode
DerivedData/
*.xcworkspace/
!default.xcworkspace/
*.xcuserstate
*.xcuserdata/

# Qt Creator
*.pro.user
*.pro.user.*

# CodeLite / KDevelop / others
*.kdev4
.kdev4/
*.workspace
*.project

# ------------------------------------------------------------
# Static analysis / formatting tool output
# ------------------------------------------------------------
clang-tidy-report.txt
clang-analyzer-*

# ------------------------------------------------------------
# Optional repo-local notes
# ------------------------------------------------------------
.todo/
.notes/
.scratches/

# ------------------------------------------------------------
# GitHub / CI artifacts generated locally
# ------------------------------------------------------------
.gha/

# ------------------------------------------------------------
# Keep placeholders when directories would otherwise be empty
# ------------------------------------------------------------
!.gitkeep

# ------------------------------------------------------------
# Explicitly keep source directories that might otherwise be shadowed
# ------------------------------------------------------------
!/assets/
!/docs/
!/engine/
!/editor/
!/games/
!/runtime/
!/scripts/
!/tests/
!/third_party/

